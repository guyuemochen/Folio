{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Folio",
  "version": "0.2.0",
  "identifier": "tech.guyuemochen.folio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Folio",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFOTU4OTFGQzk1NkNCREEKUldUYXkxYkpING1WTGxoeGhqRktHRTJpZ3NhUVg2TEdCaXRubHVENExWV1pZcGVydDZLVXF6WFkK",
      "endpoints": [
        "https://github.com/guyuemochen/folio/releases/download/stable-latest/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
